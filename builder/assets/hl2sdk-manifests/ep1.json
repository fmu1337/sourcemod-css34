{
    "name": "ep1",
    "env_var": "HL2SDK",
    "extension": "1.ep1",
    "code": 6,
    "define": "CSS",
    "platforms": {
        "windows": [
            "x86"
        ],
        "linux": [
            "x86"
        ]
    },
    "source2": false,
    "include_paths": [
        "public",
        "public/engine",
        "public/mathlib",
        "public/vstdlib",
        "public/tier0",
        "public/tier1",
        "public/toolframework",
        "public/game/server",
        "game/shared",
        "common"
    ],
    "linux": {
        "x86": {
            "dynamic_libs": [
                "linux_sdk/tier0_i486.so",
                "linux_sdk/vstdlib_i486.so"
            ]
        },
        "uses_system_cxxlib": false
    },
    "windows": {
        "x86": {
            "libs": [
                "lib/public/mathlib.lib",
                "lib/public/tier0.lib",
                "lib/public/tier1.lib",
                "lib/public/vstdlib.lib"
            ]
        }
    }
}
