#!/usr/bin/expect -f
# Send srcds console commands after map load; log full session to CONSOLE_PROBE_LOG.
set timeout [expr {[info exists env(CONSOLE_PROBE_TIMEOUT)] ? $env(CONSOLE_PROBE_TIMEOUT) : 90}]

if {![info exists env(CONSOLE_PROBE_LOG)]} {
    puts stderr "CONSOLE_PROBE_LOG is required"
    exit 1
}
log_file -noappend $env(CONSOLE_PROBE_LOG)

set server_dir [expr {[info exists env(SERVER_DIR)] ? $env(SERVER_DIR) : "/workspace/.ci-server"}]
set map [expr {[info exists env(MAP)] ? $env(MAP) : "de_dust2"}]
set port [expr {[info exists env(PORT)] ? $env(PORT) : "27015"}]
set binary [expr {[info exists env(SRCDS_BINARY)] ? $env(SRCDS_BINARY) : "./srcds_i686"}]

cd $server_dir
set env(LD_LIBRARY_PATH) ".:bin:$env(LD_LIBRARY_PATH)"

# Spawn the engine binary directly (not srcds_run). The shell wrapper has caused
# early EOF / opaque failures on some RHEL 8 images under expect's pty.
spawn $binary -game cstrike -console -nohltv \
    -nomaster -localcser -tickrate 66 \
    -ip 127.0.0.1 -port $port +ip 127.0.0.1 +sv_lan 1 +maxplayers 10 +map $map

expect {
    -re "-------- Mapchange to ${map} --------" {}
    -re "Mapchange to ${map}" {}
    eof {
        puts stderr "srcds exited before map $map loaded"
        exit 1
    }
    timeout {
        puts stderr "timeout waiting for map $map"
        exit 1
    }
}

# Give MM/SM a moment after mapchange.
sleep 3

send "status\r"
expect {
    -re {hostname|# [0-9]+} {}
    eof {
        puts stderr "srcds exited while waiting for status output"
        exit 2
    }
    timeout {
        puts stderr "timeout waiting for status output"
        exit 2
    }
}

send "version\r"
expect {
    -re {Protocol version|Exe version|version} {}
    eof {
        puts stderr "srcds exited while waiting for version output"
        exit 3
    }
    timeout {
        puts stderr "timeout waiting for version output"
        exit 3
    }
}

send "meta version\r"
expect {
    -re {Metamod|metamod|MM:S} {}
    eof {
        puts stderr "srcds exited while waiting for meta version output"
        exit 4
    }
    timeout {
        puts stderr "timeout waiting for meta version output"
        exit 4
    }
}

send "sm version\r"
expect {
    -re {SourceMod Version|SourceMod} {}
    eof {
        puts stderr "srcds exited while waiting for sm version output"
        exit 5
    }
    timeout {
        puts stderr "timeout waiting for sm version output"
        exit 5
    }
}

send "sm plugins list\r"
expect {
    -re {\[SM\] Listing [0-9]+ plugins:} {}
    eof {
        puts stderr "srcds exited while waiting for sm plugins list output"
        exit 6
    }
    timeout {
        puts stderr "timeout waiting for sm plugins list output"
        exit 6
    }
}

# Allow plugin lines to flush before shutdown.
sleep 1

send "quit\r"
expect {
    eof {}
    timeout {}
}
